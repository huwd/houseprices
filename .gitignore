# Data — multi-GB raw downloads, never committed
data/*
!data/.gitkeep
!data/SOURCES.md
!data/anna_reference.json.example
!data/cpi.csv

# Pipeline checkpoints — intermediate Parquet files
cache/*
!cache/.gitkeep

# Output CSVs and index.html are committed; images are not (except social previews)
output/*.png
output/*.jpg
!output/social-preview.png
!output/social-preview-msoa.png

# Notebook outputs are not committed (nbstripout handles this via git filter)
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# Python
__pycache__/
*.py[cod]
*.pyo
.mypy_cache/
.ruff_cache/
.pytest_cache/
htmlcov/
.coverage
*.egg-info/
dist/
build/

# uv / virtualenv
.venv/
.uv/

# Secrets — never committed; copy .env.example and fill in values
.env

# Claude Code
.claude/
.tmp/

# OS
.DS_Store
Thumbs.db
