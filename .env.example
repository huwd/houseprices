# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── EPC Open Data Communities ──────────────────────────────────────────────
# Free registration at https://epc.opendatacommunities.org/
# Your login email address and the API key shown in your account settings.
EPC_EMAIL=your-email@example.com
EPC_API_KEY=your-epc-api-key

# ── DuckDB resource limits ──────────────────────────────────────────────────
# Without a memory_limit, DuckDB uses all available RAM.  On a machine with
# limited RAM (e.g. 8 GB) the tier-2 address join can exhaust RAM + swap and
# hard-freeze the OS.  Setting memory_limit causes DuckDB to spill excess
# data to disk instead — the pipeline runs slower but the system stays alive.
#
# Recommended for an 8 GB laptop:
#   DUCKDB_MEMORY_LIMIT=3GB   (leaves headroom for Python overhead on top)
#   DUCKDB_THREADS=2          (matches physical core count; reduces peak load)
#
# Note: the DuckDB limit applies only to DuckDB's internal allocations.
# Python, pyarrow, and pandas hold additional memory on top, so the total
# process RSS will exceed this value. Set the limit ~1-2 GB below your
# available RAM to avoid oomd killing the process. Use `make run` for a
# hard cgroup cap that enforces an absolute ceiling on the whole process.
#
# Omit or leave blank to use DuckDB defaults (no memory limit, all CPU threads).
# Accepts any value DuckDB's SET memory_limit understands: 3GB, 3500MB, etc.
DUCKDB_MEMORY_LIMIT=3GB
DUCKDB_THREADS=2

