# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── EPC Open Data Communities ──────────────────────────────────────────────
# Free registration at https://epc.opendatacommunities.org/
# Your login email address and the API key shown in your account settings.
EPC_EMAIL=your-email@example.com
EPC_API_KEY=your-epc-api-key

# ── OS Data Hub ────────────────────────────────────────────────────────────
# Free API key from https://osdatahub.os.uk/
# Used to download OS Open UPRN (all addressable properties with BNG coordinates).
OS_DATA_HUB_API_KEY=your-os-data-hub-api-key
